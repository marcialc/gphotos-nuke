{
  "manifest_version": 3,
  "name": "Photo Sweep for Google Photos",
  "version": "1.0.0",
  "description": "Bulk-delete photos from your Google Photos library. Runs entirely in your browser — nothing is uploaded anywhere.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://photos.google.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Photo Sweep"
  },
  "content_scripts": [
    {
      "matches": ["https://photos.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
